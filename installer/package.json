{
  "name": "blackstar-installer",
  "productName": "Blackstar Installer",
  "version": "1.0.0",
  "description": "Installer and updater for Blackstar Support Tool",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "Blackstar Installer",
        "executableName": "BlackstarInstaller",
        "asar": true
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "BlackstarInstaller",
            "setupExe": "BlackstarInstaller-Setup.exe"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": ["win32"]
        }
      ]
    }
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "electron": "^32.0.0"
  }
}
